# R with ggplot2 - working demo
GET /r/ggplot/demo
  |> r: `
    # Create simple plot data without complex ggplot objects
    x_vals <- c(1, 2, 3, 4, 5)
    y_vals <- c(2, 4, 3, 5, 6)
    
    # Test that we can create the plot (ggplot2 already loaded)
    df <- data.frame(x = x_vals, y = y_vals)
    p <- ggplot(df, aes(x = x, y = y)) + geom_point() + geom_line()
    
    # Return summary data instead of the complex ggplot object
    list(
      plot_created = TRUE,
      data_points = length(x_vals),
      x_values = x_vals,
      y_values = y_vals,
      x_range = c(min(x_vals), max(x_vals)),
      y_range = c(min(y_vals), max(y_vals)),
      correlation = cor(x_vals, y_vals),
      plot_type = "scatter_line",
      message = "ggplot2 plot created successfully"
    )
  `

# R ggplot2 - base64 image export with error handling
GET /r/ggplot/base64
  |> r: `
    result <- tryCatch({
      # Create a simple ggplot
      df <- data.frame(
        x = c(1, 2, 3, 4, 5),
        y = c(2, 4, 3, 5, 6)
      )
      
      p <- ggplot(df, aes(x = x, y = y)) +
        geom_point(color = "blue", size = 3) +
        geom_line(color = "red") +
        labs(title = "Test Plot", x = "X Values", y = "Y Values") +
        theme_minimal()
      
      # Check if plot was created
      if (is.null(p)) {
        return(list(error = "Failed to create ggplot object"))
      }
      
      # Save to temporary file
      temp_file <- tempfile(fileext = ".png")
      ggsave(temp_file, plot = p, width = 6, height = 4, dpi = 100)
      
      # Check if file was created
      if (!file.exists(temp_file)) {
        return(list(error = "Failed to save plot file"))
      }
      
      # Get file info
      file_info <- file.info(temp_file)
      if (is.na(file_info$size) || file_info$size == 0) {
        unlink(temp_file)
        return(list(error = "Plot file is empty"))
      }
      
      # Try to encode with base64
      if (requireNamespace("base64enc", quietly = TRUE)) {
        plot_bytes <- readBin(temp_file, "raw", file_info$size)
        plot_base64 <- base64enc::base64encode(plot_bytes)
        unlink(temp_file)
        
        list(
          success = TRUE,
          plot_base64 = plot_base64,
          image_size = file_info$size,
          format = "PNG"
        )
      } else {
        # Return file info without base64
        unlink(temp_file)
        list(
          success = TRUE,
          message = "Plot created successfully but base64enc not available",
          image_size = file_info$size,
          format = "PNG"
        )
      }
    }, error = function(e) {
      list(
        success = FALSE,
        error = as.character(e),
        message = "Error in ggplot creation or file handling"
      )
    })
    
    result
  `
  |> mustache: `
    <h3>ggplot2 Generated Image</h3>
    <p>Success: {{success}}</p>
    <p>Format: {{format}}</p>
    <p>Image Size: {{image_size}} bytes</p>
    {{#success}}
    <img src="data:image/png;base64,{{plot_base64}}" style="border: 1px solid #ccc; max-width: 600px;">
    {{/success}}
    {{^success}}
    <p style="color: red;">Error: {{error}}</p>
    <p>Message: {{message}}</p>
    {{/success}}
  `

# R ggplot2 - SVG base64 export (faster rendering)
GET /r/ggplot/svg
  |> r: `
    result <- tryCatch({
      # Create a simple ggplot
      df <- data.frame(
        x = c(1, 2, 3, 4, 5),
        y = c(2, 4, 3, 5, 6)
      )
      
      p <- ggplot(df, aes(x = x, y = y)) +
        geom_point(color = "blue", size = 3) +
        geom_line(color = "red") +
        labs(title = "Test Plot (SVG)", x = "X Values", y = "Y Values") +
        theme_minimal()
      
      # Check if plot was created
      if (is.null(p)) {
        return(list(error = "Failed to create ggplot object"))
      }
      
      # Save to temporary SVG file
      temp_file <- tempfile(fileext = ".svg")
      ggsave(temp_file, plot = p, width = 6, height = 4, device = "svg")
      
      # Check if file was created
      if (!file.exists(temp_file)) {
        return(list(error = "Failed to save SVG file"))
      }
      
      # Get file info
      file_info <- file.info(temp_file)
      if (is.na(file_info$size) || file_info$size == 0) {
        unlink(temp_file)
        return(list(error = "SVG file is empty"))
      }
      
      # Try to encode with base64
      if (requireNamespace("base64enc", quietly = TRUE)) {
        svg_bytes <- readBin(temp_file, "raw", file_info$size)
        svg_base64 <- base64enc::base64encode(svg_bytes)
        unlink(temp_file)
        
        list(
          success = TRUE,
          plot_base64 = svg_base64,
          image_size = file_info$size,
          format = "SVG"
        )
      } else {
        # Return file info without base64
        unlink(temp_file)
        list(
          success = TRUE,
          message = "SVG created successfully but base64enc not available",
          image_size = file_info$size,
          format = "SVG"
        )
      }
    }, error = function(e) {
      list(
        success = FALSE,
        error = as.character(e),
        message = "Error in ggplot SVG creation or file handling"
      )
    })
    
    result
  `
  |> mustache: `
    <h3>ggplot2 Generated SVG Image</h3>
    <p>Success: {{success}}</p>
    <p>Format: {{format}}</p>
    <p>Image Size: {{image_size}} bytes</p>
    {{#success}}
    <img src="data:image/svg+xml;base64,{{plot_base64}}" style="border: 1px solid #ccc; max-width: 600px;">
    {{/success}}
    {{^success}}
    <p style="color: red;">Error: {{error}}</p>
    <p>Message: {{message}}</p>
    {{/success}}
  `

# R ggplot2 - Fast SVG output (no temp files, direct memory)
GET /r/ggplot/svg-fast
  |> r: `
    result <- tryCatch({
      # Create a simple ggplot
      df <- data.frame(
        x = c(1, 2, 3, 4, 5),
        y = c(2, 4, 3, 5, 6)
      )
      
      p <- ggplot(df, aes(x = x, y = y)) +
        geom_point(color = "blue", size = 3) +
        geom_line(color = "red") +
        labs(title = "Fast SVG Plot", x = "X Values", y = "Y Values") +
        theme_minimal()
      
      # Generate SVG directly to string using svglite
      svg_string <- svglite::svgstring(width = 6, height = 4)
      print(p)
      svg_content <- svg_string()
      dev.off()
      
      list(
        success = TRUE,
        svg_content = svg_content,
        format = "SVG",
        method = "direct_memory"
      )
    }, error = function(e) {
      list(
        success = FALSE,
        error = as.character(e),
        message = "Error in fast SVG generation"
      )
    })
    
    result
  `

# Base R plot() - Fast SVG generation (speed test)
GET /r/plot/svg-fast
  |> r: `
    result <- tryCatch({
      # Create simple data
      x <- c(1, 2, 3, 4, 5)
      y <- c(2, 4, 3, 5, 6)
      
      # Generate SVG directly using base R plot
      svg_string <- svglite::svgstring(width = 6, height = 4)
      
      # Use base R plotting (much faster than ggplot2)
      plot(x, y, 
           type = "b",                    # both points and lines
           col = "blue", 
           pch = 16,                      # solid circles
           lwd = 2,                       # line width
           main = "Fast Base R Plot",
           xlab = "X Values",
           ylab = "Y Values",
           cex = 1.5)                     # point size
      
      # Add grid
      grid()
      
      svg_content <- svg_string()
      dev.off()
      
      list(
        success = TRUE,
        svg_content = svg_content,
        format = "SVG",
        method = "base_R_plot",
        note = "Should be much faster than ggplot2"
      )
    }, error = function(e) {
      list(
        success = FALSE,
        error = as.character(e),
        message = "Error in base R plot generation"
      )
    })
    
    result
  `

