POST /todos/add
  |> jq: `{ 
    sqlParams: [.body.title, false, "1"]
  }`
  |> pg: `INSERT INTO todos (title, completed, user_id) VALUES ($1, $2, $3) RETURNING *`
  |> jq: `{
    newTodo: (.data.rows[0] | . + {id: (.id | tostring)})
  }`
  |> mustache: `
          <li class="todo-item">
            <div class="todo-content">
              <div class="todo-title">{{newTodo.title}}</div>
              <div class="todo-date">Created: {{newTodo.created_at}}</div>
            </div>
            <div class="todo-actions">
              <button hx-post="/todos/{{newTodo.id}}/toggle" hx-target="closest .todo-item" hx-swap="outerHTML" class="btn btn-sm btn-success">Mark Complete</button>
            </div>
          </li>
  `

POST /todos/:id/toggle
  |> jq: `{ sqlParams: [.params.id], todoId: .params.id }`
  |> pg: `SELECT * FROM todos WHERE id = $1`
  |> jq: `{ 
    sqlParams: [(.data.rows[0].completed | not), .todoId],
    currentTodo: .data.rows[0]
  }`
  |> pg: `UPDATE todos SET completed = $1, updated_at = CURRENT_TIMESTAMP WHERE id = $2 RETURNING *`
  |> jq: `{
    todo: (.data.rows[0] | . + {id: (.id | tostring)})
  }`
  |> mustache: `
          <li class="todo-item {{#todo.completed}}completed{{/todo.completed}}">
            <div class="todo-content">
              <div class="todo-title {{#todo.completed}}completed{{/todo.completed}}">{{todo.title}}</div>
              <div class="todo-date">Created: {{todo.created_at}}</div>
            </div>
            <div class="todo-actions">
              {{#todo.completed}}
              <button hx-post="/todos/{{todo.id}}/toggle" hx-target="closest .todo-item" hx-swap="outerHTML" class="btn btn-sm">Mark Incomplete</button>
              {{/todo.completed}}
              {{^todo.completed}}
              <button hx-post="/todos/{{todo.id}}/toggle" hx-target="closest .todo-item" hx-swap="outerHTML" class="btn btn-sm btn-success">Mark Complete</button>
              {{/todo.completed}}
            </div>
          </li>
  `

GET /hello-mustache
  |> jq: `{ name: "World", message: "Hello from mustache!" }`
  |> mustache: `
    <html>
      <head>
        <title>{{message}}</title>
      </head>
      <body>
        <h1>{{message}}</h1>
        <p>Hello, {{name}}!</p>
      </body>
    </html>
  `

GET /mustache-error-test
  |> jq: `{ invalid: "data" }`
  |> mustache: `{{syntax_error`

mustache cardPartial = `
  <div class="card">
    <h3>{{title}}</h3>
    <p>{{description}}</p>
  </div>
`

mustache headerPartial = `
  <header>
    <h1>{{siteName}}</h1>
    <nav>{{>navPartial}}</nav>
  </header>
`

mustache navPartial = `
  <ul>
    <li><a href="/">Home</a></li>
    <li><a href="/about">About</a></li>
  </ul>
`

GET /test-partials
  |> jq: `{ 
    title: "Welcome", 
    description: "This is a test card",
    siteName: "My Website"
  }`
  |> mustache: `
    <html>
      <head>
        <title>{{siteName}}</title>
      </head>
      <body>
        {{>headerPartial}}
        <main>
          {{>cardPartial}}
        </main>
      </body>
    </html>
  `

GET /test-missing-partial
  |> jq: `{ title: "Test" }`
  |> mustache: `
    <html>
      <body>
        {{>nonexistentPartial}}
      </body>
    </html>
  `

GET /test-sql-error-mustache
  |> jq: `{ sqlParams: [] }`
  |> pg: `SELECT * FROM nonexistent_table`
  |> result
    ok(200):
      |> jq: `{success: true, data: .data}`
    sqlError(500):
      |> jq: `{
        error: "Database error",
        sqlstate: .errors[0].sqlstate,
        message: .errors[0].message,
        query: .errors[0].query
      }`
      |> mustache: `{{error}}`
    default(500):
      |> jq: `{error: "Internal server error"}`
      |> mustache: `{{error}}`